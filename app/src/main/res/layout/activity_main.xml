<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D1A">

    <!-- 背景光圈装饰 -->
    <View
        android:id="@+id/bgGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_glow"
        android:alpha="0.3"
        android:layout_centerInParent="true" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔊 声音按钮"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp" />

    <!-- 提示文字 -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="正在加载音频..."
        android:textSize="15sp"
        android:textColor="#AAAACC"
        android:layout_below="@id/tvTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp" />

    <!-- 主点击按钮 -->
    <View
        android:id="@+id/btnClick"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/btn_click"
        android:clickable="true"
        android:focusable="true"
        android:elevation="12dp"
        android:layout_centerInParent="true" />

    <!-- 按钮中央图标 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👆"
        android:textSize="52sp"
        android:elevation="13dp"
        android:clickable="false"
        android:focusable="false"
        android:layout_centerInParent="true" />

    <!-- 点击次数 -->
    <TextView
        android:id="@+id/tvCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已点击：0 次"
        android:textSize="20sp"
        android:textColor="#7B68EE"
        android:textStyle="bold"
        android:layout_below="@id/btnClick"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="36dp" />

    <!-- 底部提示 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="每次点击都会有声音和震动反馈"
        android:textSize="13sp"
        android:textColor="#666688"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="32dp" />

</RelativeLayout>
